{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "mipress/core",
    "type": "library",
    "description": "MiPress CMS core package.",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "awcodes/botly": "^1.0",
        "awcodes/mason": "^3.0",
        "codewithdennis/filament-select-tree": "4.x",
        "filament/filament": "^5.0",
        "malzariey/filament-daterangepicker-filter": "^5.0",
        "spatie/laravel-medialibrary": "^11.17",
        "spatie/laravel-permission": "^7.0",
        "spatie/laravel-sluggable": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "MiPress\\Core\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "MiPress\\Core\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MiPress\\Core\\MiPressServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
